---
import type { ImageRef } from "@lib/types";
import { storyblokImage, storyblokSrcset } from "@lib/image";

interface Props {
  image: ImageRef | null;
  title: string;
  /** aspect-ratio css value, e.g. "4 / 3" */
  ratio?: string;
  width?: number;
  eager?: boolean;
  class?: string;
}
const {
  image,
  title,
  ratio = "4 / 3",
  width = 1080,
  eager = false,
  class: cls = "",
} = Astro.props;

const srcset = image ? storyblokSrcset(image.src) : undefined;
const src = image ? storyblokImage(image.src, { width }) : "";
---

{
  image ? (
    <img
      class:list={["cover-img", cls]}
      src={src}
      srcset={srcset}
      sizes="(min-width: 900px) 50vw, 100vw"
      alt={image.alt || title}
      loading={eager ? "eager" : "lazy"}
      decoding="async"
      style={`aspect-ratio:${ratio}`}
    />
  ) : (
    /* No image — an intentional editorial "plate" instead of a broken box. */
    <div
      class:list={["cover-plate surface-paper", cls]}
      style={`aspect-ratio:${ratio}`}
      role="img"
      aria-label={title}
    >
      <span class="cover-plate__title">{title}</span>
    </div>
  )
}

<style>
  .cover-img {
    width: 100%;
    object-fit: cover;
    border: 1px solid var(--color-rule);
  }
  .cover-plate {
    width: 100%;
    display: grid;
    place-items: center;
    padding: 1.5rem;
    border: 1px solid var(--color-rule);
    overflow: hidden;
  }
  .cover-plate__title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.5rem, 4vw, 2.75rem);
    line-height: 1.05;
    color: var(--color-ink-red);
    text-align: center;
    text-shadow: 0 1px 1px color-mix(in srgb, var(--color-dark) 12%, transparent);
  }
</style>
