---
import type { SiteSettings } from "@lib/types";

interface Props {
  settings: SiteSettings;
}
const { settings } = Astro.props;
const path = Astro.url.pathname.replace(/\/$/, "") || "/";

const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(href + "/");
---

<header class="site-header above-texture">
  <div class="container-editorial header-inner">
    <a href="/" class="brand" aria-label={`${settings.site_title} — home`}>
      {settings.site_title}
    </a>

    <nav class="nav-desktop" aria-label="Primary">
      {
        settings.navigation.map((item) => (
          <a
            href={item.href}
            class:list={["nav-link", isActive(item.href) && "is-active"]}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <details class="nav-mobile">
      <summary aria-label="Toggle menu"><span>Menu</span></summary>
      <nav class="nav-mobile__list" aria-label="Primary">
        {
          settings.navigation.map((item) => (
            <a
              href={item.href}
              class:list={["nav-link", isActive(item.href) && "is-active"]}
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </details>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(6px);
    background-color: color-mix(in srgb, var(--color-linen) 82%, transparent);
    border-bottom: 1px solid var(--color-rule);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1.05rem;
    padding-bottom: 1.05rem;
  }
  .brand {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.4rem;
    color: var(--color-ink-red);
    transition: color 160ms var(--ease-out);
  }
  .brand:hover {
    color: var(--color-wine);
  }

  .nav-desktop {
    display: none;
    gap: 1.6rem;
  }
  .nav-link {
    font-family: var(--font-sans);
    font-size: 0.74rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-muted);
    position: relative;
    padding-bottom: 2px;
    transition: color 160ms var(--ease-out);
  }
  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background-color: var(--color-ink-red);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 220ms var(--ease-out);
  }
  .nav-link:hover,
  .nav-link.is-active {
    color: var(--color-ink-red);
  }
  .nav-link:hover::after,
  .nav-link.is-active::after {
    transform: scaleX(1);
  }

  /* Mobile disclosure — native <details>, no JS. */
  .nav-mobile summary {
    list-style: none;
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: 0.74rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-ink-red);
    border: 1px solid var(--color-rule);
    border-radius: 2px;
    padding: 0.5rem 0.85rem;
    transition: transform 160ms var(--ease-out);
  }
  .nav-mobile summary::-webkit-details-marker {
    display: none;
  }
  .nav-mobile summary:active {
    transform: scale(0.97);
  }
  .nav-mobile[open] summary span::after {
    content: " ×";
  }
  .nav-mobile__list {
    position: absolute;
    right: clamp(1.25rem, 5vw, 4rem);
    margin-top: 0.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding: 1.1rem 1.4rem;
    background-color: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 3px;
    box-shadow: 0 12px 30px color-mix(in srgb, var(--color-dark) 14%, transparent);
  }

  @media (min-width: 768px) {
    .nav-desktop {
      display: flex;
    }
    .nav-mobile {
      display: none;
    }
  }
</style>
