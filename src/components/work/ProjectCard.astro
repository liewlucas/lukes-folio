---
import type { Project } from "@lib/types";
import Cover from "@components/ui/Cover.astro";

interface Props {
  project: Project;
  eager?: boolean;
}
const { project, eager = false } = Astro.props;
---

<a class="project-card" href={`/work/${project.slug}`}>
  <div class="project-card__media">
    <Cover
      image={project.cover_image}
      title={project.title}
      ratio="4 / 3"
      eager={eager}
    />
  </div>
  <div class="project-card__meta">
    <div class="project-card__top">
      <span class="label label-red">{project.year}</span>
      <span class="label">{project.role}</span>
    </div>
    <h3 class="project-card__title">{project.title}</h3>
    <p class="project-card__summary">{project.summary}</p>
    {
      project.stack.length > 0 && (
        <ul class="project-card__stack">
          {project.stack.map((s) => (
            <li class="label">{s}</li>
          ))}
        </ul>
      )
    }
  </div>
</a>

<style>
  .project-card {
    display: block;
  }
  .project-card__media {
    overflow: hidden;
    border-radius: 2px;
  }
  /* Emil: slight image movement on hover — transform/opacity only, GPU. */
  .project-card :global(.cover-img),
  .project-card :global(.cover-plate) {
    transition: transform 500ms var(--ease-out);
  }
  .project-card__meta {
    margin-top: 1.1rem;
  }
  .project-card__top {
    display: flex;
    gap: 1rem;
    align-items: baseline;
  }
  .project-card__title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.6rem, 3vw, 2.25rem);
    line-height: 1.05;
    margin-top: 0.4rem;
    color: var(--color-ink-red);
    transition: color 160ms var(--ease-out);
  }
  .project-card__summary {
    margin-top: 0.5rem;
    color: var(--color-dark);
    max-width: 46ch;
  }
  .project-card__stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
    margin-top: 0.9rem;
    list-style: none;
    padding: 0;
  }

  @media (hover: hover) and (pointer: fine) {
    .project-card:hover :global(.cover-img),
    .project-card:hover :global(.cover-plate) {
      transform: scale(1.03);
    }
    .project-card:hover .project-card__title {
      color: var(--color-wine);
    }
  }
</style>
