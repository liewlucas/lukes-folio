---
import { storyblokEditable } from "@storyblok/astro";
const { blok } = Astro.props;
---

<figure class="container-editorial sb-quote" {...storyblokEditable(blok)}>
  <blockquote class="sb-quote__text">{blok.quote}</blockquote>
  {blok.attribution && <figcaption class="label">— {blok.attribution}</figcaption>}
</figure>

<style>
  .sb-quote {
    padding-block: clamp(2rem, 5vw, 3.5rem);
    max-width: 48rem;
  }
  .sb-quote__text {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.6rem, 4vw, 2.6rem);
    line-height: 1.25;
    color: var(--color-ink-red);
    border: 0;
    padding: 0;
  }
  .sb-quote figcaption {
    margin-top: 1.25rem;
  }
</style>
