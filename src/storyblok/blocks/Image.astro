---
import { storyblokEditable } from "@storyblok/astro";
import { storyblokImage, storyblokSrcset } from "@lib/image";
const { blok } = Astro.props;
const src = blok.image?.filename ?? "";
const alt = blok.image?.alt ?? blok.caption ?? "";
---

<figure class="container-editorial sb-image" {...storyblokEditable(blok)}>
  {
    src && (
      <img
        src={storyblokImage(src, { width: 1600 })}
        srcset={storyblokSrcset(src)}
        sizes="100vw"
        alt={alt}
        loading="lazy"
        decoding="async"
      />
    )
  }
  {blok.caption && <figcaption class="label">{blok.caption}</figcaption>}
</figure>

<style>
  .sb-image {
    padding-block: clamp(1.5rem, 4vw, 2.5rem);
  }
  .sb-image img {
    width: 100%;
    border: 1px solid var(--color-rule);
    border-radius: 2px;
  }
  .sb-image figcaption {
    margin-top: 0.75rem;
  }
</style>
