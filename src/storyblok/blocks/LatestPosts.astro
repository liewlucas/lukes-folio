---
import { storyblokEditable } from "@storyblok/astro";
import NoteCard from "@components/notes/NoteCard.astro";
import { getLatestPosts } from "@lib/content";

const { blok } = Astro.props;
const limit = Number(blok.limit) || 3;
const posts = await getLatestPosts(limit);
---

<section class="container-editorial sb-latest" {...storyblokEditable(blok)}>
  <div class="sb-latest__head">
    <span class="label label-red">{blok.heading ?? "Latest notes"}</span>
    <a class="link-underline" href="/notes">All notes →</a>
  </div>
  <div class="sb-latest__list">
    {posts.map((post) => <NoteCard post={post} />)}
  </div>
</section>

<style>
  .sb-latest {
    padding-block: clamp(2rem, 5vw, 3.5rem);
  }
  .sb-latest__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-rule);
  }
  .sb-latest__list {
    margin-top: 1rem;
  }
</style>
