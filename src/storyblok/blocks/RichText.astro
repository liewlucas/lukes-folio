---
import { storyblokEditable, renderRichText } from "@storyblok/astro";
const { blok } = Astro.props;
const html = blok.content ? renderRichText(blok.content) : "";
---

<section class="container-editorial sb-richtext" {...storyblokEditable(blok)}>
  <div class="prose-editorial" set:html={html} />
</section>

<style>
  .sb-richtext {
    padding-block: clamp(1.5rem, 4vw, 2.5rem);
  }
  .sb-richtext .prose-editorial {
    font-size: 1.12rem;
  }
</style>
