---
import { storyblokEditable, renderRichText } from "@storyblok/astro";
const { blok } = Astro.props;
const html = blok.body ? renderRichText(blok.body) : "";
---

<section class="container-editorial sb-process" {...storyblokEditable(blok)}>
  <span class="label label-red">{blok.label ?? "Process"}</span>
  <div class="sb-process__body">
    {blok.heading && <h2 class="title">{blok.heading}</h2>}
    <div class="prose-editorial" set:html={html} />
  </div>
</section>

<style>
  .sb-process {
    padding-block: clamp(1.75rem, 4vw, 2.75rem);
    border-top: 1px solid var(--color-rule);
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }
  .sb-process__body .title {
    margin-bottom: 1rem;
  }
  @media (min-width: 820px) {
    .sb-process {
      grid-template-columns: 14rem 1fr;
      gap: 2rem;
    }
  }
</style>
