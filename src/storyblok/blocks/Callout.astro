---
import { storyblokEditable } from "@storyblok/astro";
const { blok } = Astro.props;
---

<aside class="container-editorial sb-callout" {...storyblokEditable(blok)}>
  <div class="sb-callout__inner">
    {blok.label && <span class="label label-red">{blok.label}</span>}
    <p class="sb-callout__text">{blok.text}</p>
  </div>
</aside>

<style>
  .sb-callout {
    padding-block: clamp(1.5rem, 4vw, 2.5rem);
  }
  .sb-callout__inner {
    border-left: 2px solid var(--color-ink-red);
    padding-left: 1.5rem;
    max-width: 52ch;
  }
  .sb-callout__text {
    margin-top: 0.6rem;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.25rem, 2.5vw, 1.7rem);
    line-height: 1.3;
    color: var(--color-dark);
  }
</style>
